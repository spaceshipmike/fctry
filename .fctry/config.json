{
  "versions": {
    "external": {
      "type": "external",
      "current": "0.66.0",
      "propagationTargets": [
        {
          "file": ".claude-plugin/plugin.json",
          "field": "version"
        },
        {
          "file": ".claude-plugin/plugin.json",
          "field": "description",
          "pattern": "Software Factory v{version}"
        },
        {
          "file": ".fctry/spec.md",
          "field": "plugin-version"
        }
      ],
      "incrementRules": {
        "patch": "auto-per-chunk",
        "minor": "suggest-at-plan-completion",
        "major": "suggest-at-experience-milestone"
      }
    },
    "spec": {
      "type": "internal",
      "current": "3.91",
      "propagationTargets": [
        {
          "file": ".fctry/spec.md",
          "field": "spec-version"
        }
      ],
      "incrementRules": {
        "minor": "auto-on-evolve"
      }
    }
  },
  "relationshipRules": [
    {
      "when": {
        "type": "spec",
        "change": "major"
      },
      "action": "suggest-external-minor-bump"
    }
  ],
  "formatVersion": "0.65.0",
  "evaluation": {
    "trials": 3,
    "passThreshold": 2,
    "models": {}
  },
  "foreman": {
    "enabled": false,
    "discoveryEnabled": true,
    "budgetPerDay": 500000,
    "cycleCapPerRun": 3,
    "quietHours": {
      "start": 23,
      "end": 7
    },
    "eligibleTypes": [
      "reference"
    ]
  }
}
